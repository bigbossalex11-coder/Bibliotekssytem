@page "/loans"
@using LibrarySystem.Core
@using LibrarySystem.Data.Interfaces
@inject IBookRepository BookRepo
@inject IMemberRepository MemberRepo
@inject ILoanService LoanService
@rendermode InteractiveServer

<h1>Lån</h1>

<div class="mb-2">
    <input type="text" class="form-control" value="@bookSearch" @oninput="SearchBooks" placeholder="Sök bok..." />
    @if (filteredBooks.Any())
    {
        <ul class="list-group mt-1">
            @foreach (var book in filteredBooks)
            {
                <li class="list-group-item list-group-item-action" style="cursor:pointer" @onclick="() => SelectBook(book)">
            @book.Title — @book.Author
        </li>
                }
        </ul>
    }
    @if (selectedBookId != 0)
    {
        <p class="mt-1 text-success">Vald bok: @books.First(b => b.Id == selectedBookId).Title</p>
    }
</div>
<div class="mb-2">
     <select class="form-select" @bind="selectedMemberId">
        <option value="0">-- Välj medlem --</option>
        @foreach (var member in members)
        {
            <option value="@member.Id">@member.Name</option>
        }
    </select>
</div>
<button class="btn btn-primary" @onclick="AddLoan">Lägg till</button>

@if (errorMessage != "")
{
    <p class="text-danger mt-2">@errorMessage</p>
}
<input type="text" class="form-control mb-3 mt-3" @bind-value="searchTerm" @bind-value:event="oninput"
       placeholder="Sök bok eller medlem..." />

<table class="table mt-4">
    <thead>
        <tr>
            <th>Bok</th>
            <th>Medlem</th>
            <th>Lånedatum</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var loan in loans.Where(l => !l.IsReturned &&
                (l.Book.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                l.Member.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))))
        {
            <tr>
                <td>@loan.Book.Title</td>
                <td>@loan.Member.Name</td>
                <td>@loan.LoanDate.ToShortDateString()</td>
                <td>
                    <button class="btn btn-success btn-sm" @onclick="() => ReturnLoan(loan)">Återlämna</button>
                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteLoan(loan)">Ta bort</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    private List<Loan> loans = new();
    private List<Book> books = new();
    private List<Member> members = new();
    private int selectedBookId = 0;
    private int selectedMemberId = 0;
    private string errorMessage = "";
    private string searchTerm = "";
    private string bookSearch = "";
    private List<Book> filteredBooks = new();

    protected override async Task OnInitializedAsync()
    {
        books = await BookRepo.GetAllAsync();
        members = await MemberRepo.GetAllAsync();
        loans = await LoanService.GetActiveLoansAsync();
    }

    private async Task AddLoan()
    {
        if (selectedBookId == 0 || selectedMemberId == 0)
        {
            errorMessage = "Välj en bok och en medlem.";
            return;
        }
        errorMessage = await LoanService.AddLoanAsync(selectedBookId, selectedMemberId) ?? "";
        if (errorMessage == "")
        {
            loans = await LoanService.GetActiveLoansAsync();
            selectedBookId = 0;
            bookSearch = "";
        }
    }

    private async Task ReturnLoan(Loan loan)
    {
        await LoanService.ReturnLoanAsync(loan);
        loans = await LoanService.GetActiveLoansAsync();
    }
    private async Task DeleteLoan(Loan loan)
    {
        await LoanService.DeleteLoanAsync(loan.Id);
        loans = await LoanService.GetActiveLoansAsync();
    }
    private void SearchBooks(ChangeEventArgs e)
    {
        bookSearch = e.Value?.ToString() ?? "";
        filteredBooks = books.Where(b => b.IsAvailable &&
            b.Title.Contains(bookSearch, StringComparison.OrdinalIgnoreCase)).ToList();
    }
     private void SelectBook(Book book)
  {
      selectedBookId = book.Id;
      bookSearch = book.Title;
      filteredBooks = new();
  }
}

