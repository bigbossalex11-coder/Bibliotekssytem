  @page "/members"
  @using LibrarySystem.Core
  @using LibrarySystem.Data.Interfaces
  @inject IMemberService MemberService
  @rendermode InteractiveServer

  <h1>Medlemmar</h1>

  <EditForm Model="newMember" OnValidSubmit="AddMember">
      <DataAnnotationsValidator />
      <ValidationSummary />
      <div class="mb-2">
          <InputText class="form-control" @bind-Value="newMember.Name" placeholder="Namn" />
      </div>
      <div class="mb-2">
          <InputText class="form-control" @bind-Value="newMember.MembershipID" placeholder="Medlems-ID" />
      </div>
      <button class="btn btn-primary" type="submit">Lägg till</button>
    @if (errorMessage != "")
    {
        <p class="text-danger mt-2">@errorMessage</p>
    }
  </EditForm>

  <table class="table mt-4">
      <thead>
          <tr>
              <th>Namn</th>
              <th>Medlems-ID</th>
              <th></th>
          </tr>
      </thead>
      <tbody>
        @if (!members.Any())
        {
            <tr><td colspan="3" class="text-muted">Inga medlemmar tillagda ännu.</td></tr>
        }
          @foreach (var member in members)
          {
              <tr>
                  <td>@member.Name</td>
                  <td>@member.MembershipID</td>
                  <td>
                      <button class="btn btn-danger btn-sm" @onclick="() => DeleteMember(member)">Ta bort</button>
                  </td>
              </tr>
          }
      </tbody>
  </table>

@code {
	private List<Member> members = new();
    private string errorMessage = "";

	protected override async Task OnInitializedAsync()
	{
		members = await MemberService.GetActiveMemberAsync();
	}

	private Member newMember = new Member("", true);

    private async Task AddMember()
    {
        errorMessage = await MemberService.AddMemberAsync(newMember.Name) ?? "";
        if (errorMessage == "")
        {
            members = await MemberService.GetActiveMemberAsync();
            newMember = new Member("", true);
        }
    }
    private async Task DeleteMember(Member member)
    {
        await MemberService.DeleteMemberAsync(member.Id);
        members = await MemberService.GetActiveMemberAsync();
    }
}
