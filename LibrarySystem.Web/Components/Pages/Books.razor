@page "/books"
@using LibrarySystem.Core
@using LibrarySystem.Data.Interfaces
@inject IBookRepository BookRepo
@rendermode InteractiveServer

<h1>Böcker</h1>

<EditForm Model="newBook" OnValidSubmit="AddBook">
    <DataAnnotationsValidator />
    <ValidationSummary />
    <div class="mb-2">
        <InputText class="form-control" @bind-Value="newBook.ISBN" placeholder="ISBN" />
    </div>
    <div class="mb-2">
        <InputText class="form-control" @bind-Value="newBook.Title" placeholder="Titel" />
    </div>
    <div class="mb-2">
        <InputText class="form-control" @bind-Value="newBook.Author" placeholder="Författare" />
    </div>
    <div class="mb-2">
        <InputNumber class="form-control" @bind-Value="newBook.PublishedYear" placeholder="Utgivningsår" />
    </div>
    <button class="btn btn-primary" type="submit">Lägg till</button>
</EditForm>

<table class="table mt-4">
    <thead>
        <tr>
            <th>Titel</th>
            <th>Författare</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in books)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>
                    <button class="btn btn-danger btn-sm" @onclick="() => DeleteBook(book)">Ta bort</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
	private List<Book> books = new();

	protected override async Task OnInitializedAsync()
	{
		books = await BookRepo.GetAllAsync();
	}

	private Book newBook = new Book("", "", "", 0);

	private async Task AddBook()
	{
		await BookRepo.AddAsync(newBook);
		books.Add(newBook);
		newBook = new Book("", "", "", 0);
	}
	private async Task DeleteBook(Book book)
	{
		await BookRepo.DeleteAsync(book.Id);
		books.Remove(book);
	}
}
